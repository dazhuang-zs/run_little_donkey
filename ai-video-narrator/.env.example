# OpenAI配置
OPENAI_API_KEY=sk-xxx

# Azure TTS配置
AZURE_TTS_KEY=xxx
AZURE_TTS_REGION=eastasia

# 阿里云OSS配置
OSS_ACCESS_KEY_ID=xxx
OSS_ACCESS_KEY_SECRET=xxx
OSS_BUCKET_NAME=xxx
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# 数据库配置
DATABASE_URL=sqlite:///./data.db

# Redis配置（可选，用于任务队列）
REDIS_URL=redis://localhost:6379/0

# API配置
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true