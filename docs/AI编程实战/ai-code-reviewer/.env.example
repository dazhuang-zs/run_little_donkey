# LLM API Configuration
# 支持所有兼容OpenAI接口的服务（OpenAI、Azure、vLLM、Ollama等）
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# Review Configuration
# 审阅维度：security,performance,style,logic 逗号分隔
REVIEW_DIMENSIONS=security,performance,style,logic
# 每次审阅最大token数（估计值，用于大diff分片）
MAX_TOKENS_PER_CHUNK=4000
# 并发请求数
CONCURRENCY=3
